---
import PageLayout from '@/layouts/PageLayout.astro'

const product = {
  name: 'Tree Pad 3',
  model: 'L300PAS',
  os: 'Leaf OS 5',
  tagline: '为创作而生',
}

const display = {
  size: '11"',
  resolution: '2560 × 1600',
  refreshRate: '120Hz',
  standard: 'HDR10 LED',
  dolby: '杜比视界',
}

const performance = {
  processor: '第3代 Trdom 八核处理器',
  cpu: '3.11GHz',
  ram: ['8GB', '12GB', '16GB'],
  rom: ['256GB', '512GB'],
  flash: 'UFS 3.1',
}

const camera = {
  rearMain: '2400万像素',
  rearWide: '1200万像素',
  front: '1200万像素',
}

const network = {
  wifi: 'Wi-Fi 6',
  bluetooth: 'Bluetooth 5.3',
  ethernet: '千兆以太网',
}

const audio = {
  speakers: '六扬声器',
  dolbyAtmos: '杜比全景声',
  customSound: 'Nature Surround',
  mics: '4颗降噪麦克风',
}

const battery = {
  capacity: '12000mAh',
  fastCharge: '90W',
  pdCharge: '40W PD',
}

const security = {
  hardware: 'Nature Leaf 底层硬件保护',
  encryption: 'TEE 可信执行环境',
  network: 'ARP 网络攻击防护',
  boot: 'LBJ 3.0 启动安全保护',
}

const specs = [
  { icon: 'bi-display', label: '屏幕尺寸', value: display.size, detail: display.resolution },
  { icon: 'bi-cpu', label: '处理器', value: performance.cpu, detail: performance.processor },
  { icon: 'bi-memory-stick', label: '运行内存', value: performance.ram[2], detail: performance.flash },
  { icon: 'bi-battery-full', label: '电池容量', value: battery.capacity, detail: battery.fastCharge + ' 超级快充' },
  { icon: 'bi-camera', label: '后置主摄', value: camera.rearMain, detail: '等效 35mm 焦距' },
  { icon: 'bi-speaker', label: '扬声器', value: audio.speakers, detail: '杜比全景声' },
  { icon: 'bi-wifi', label: '无线网络', value: network.wifi, detail: network.bluetooth },
  { icon: 'bi-shield-lock', label: '安全防护', value: '硬件级', detail: 'TEE 加密' },
]

const displayStats = [
  { value: display.size, label: '屏幕尺寸' },
  { value: display.refreshRate, label: '自适应刷新率' },
  { value: display.resolution, label: '分辨率' },
  { value: 'HDR10', label: '显示标准' },
]

const securityItems = [
  { icon: 'bi-shield', title: security.hardware, desc: '底层硬件保护机制，从源头保障系统安全' },
  { icon: 'bi-lock', title: security.encryption, desc: 'TEE 可信执行环境，硬件级数据加密' },
  { icon: 'bi-network', title: security.network, desc: 'ARP 网络攻击防护，守护网络安全' },
  { icon: 'bi-power', title: security.boot, desc: 'LBJ 3.0 启动安全保护，防止未授权引导' },
]
---

<PageLayout
  title="Tree Pad 3 - 搭载 Leaf OS 的旗舰平板"
  description="Tree Pad 3 是搭载 Leaf OS 5 的旗舰级平板电脑，配备 11 英寸 2.5K 120Hz 屏幕、第3代 Trdom 处理器和六扬声器声学系统。"
>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <style>
    :root {
      --accent: rgb(var(--color-accent));
      --bg-root: rgb(var(--color-bg-root));
      --bg-primary: rgb(var(--color-bg-primary));
      --bg-secondary: rgb(var(--color-bg-secondary));
      --text-primary: rgb(var(--color-text-primary));
      --text-secondary: rgb(var(--color-text-secondary));
      --border: rgb(var(--color-border-primary));
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.9375rem;
      text-decoration: none;
      transition: all 0.2s ease;
      cursor: pointer;
      border: none;
    }
    .btn-primary {
      background: var(--accent);
      color: #fff;
    }
    .btn-primary:hover { filter: brightness(0.9); }
    .btn-outline {
      background: transparent;
      color: var(--text-primary);
      border: 1px solid var(--border);
    }
    .btn-outline:hover { border-color: var(--accent); }

    .hero-section {
      position: relative;
      min-height: calc(100dvh - 64px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 4rem 0;
      overflow: hidden;
    }

    .hero-glow {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 800px; height: 800px;
      background: radial-gradient(circle at center, color-mix(in srgb, var(--accent) 25%, transparent) 0%, transparent 70%);
      filter: blur(100px);
      pointer-events: none;
      z-index: 0;
    }

    .hero-content {
      position: relative;
      z-index: 10;
      display: grid;
      grid-template-columns: 1fr;
      gap: 3rem;
      max-width: 1200px;
      width: 100%;
      padding: 0 2rem;
      align-items: center;
    }

    @media (min-width: 1024px) {
      .hero-content { grid-template-columns: 1fr 1.2fr; }
    }

    .hero-text {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .hero-eyebrow {
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
    }

    .hero-title {
      font-size: 4rem;
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.03em;
    }

    .hero-subtitle {
      font-size: 1.75rem;
      font-weight: 300;
      color: var(--text-secondary);
      letter-spacing: -0.02em;
    }

    .hero-desc {
      font-size: 1.125rem;
      color: var(--text-secondary);
      line-height: 1.7;
      max-width: 45ch;
    }

    .hero-visual {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .tablet-outline {
      position: relative;
      width: 100%;
      max-width: 500px;
      aspect-ratio: 16/10;
      border-radius: 32px;
      border: 3px solid var(--border);
      background: var(--bg-secondary);
      padding: 8px;
      box-shadow: 0 25px 80px -20px rgba(0, 0, 0, 0.3);
    }

    .tablet-screen {
      width: 100%;
      height: 100%;
      border-radius: 26px;
      background: linear-gradient(135deg, var(--bg-primary) 0%, color-mix(in srgb, var(--bg-primary) 95%, var(--accent) 5%) 100%);
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .tablet-bezel {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 95%;
      height: 95%;
      border-radius: 22px;
      border: 1px solid var(--border);
      pointer-events: none;
    }

    .tablet-home-indicator {
      position: absolute;
      bottom: 12px;
      left: 50%;
      transform: translateX(-50%);
      width: 40%;
      height: 3px;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 2px;
    }

    .screen-content {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem;
    }

    .screen-row {
      display: flex;
      gap: 0.75rem;
    }

    .screen-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: color-mix(in srgb, var(--accent) 20%, transparent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      color: var(--accent);
    }

    .screen-bar {
      height: 8px;
      background: var(--border);
      border-radius: 4px;
      overflow: hidden;
    }

    .screen-bar-fill {
      height: 100%;
      background: var(--accent);
      border-radius: 4px;
    }

    .specs-section {
      padding: 8rem 2rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    .section-header {
      text-align: center;
      margin-bottom: 6rem;
    }

    .section-title {
      font-size: 2.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }

    .section-desc {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 50ch;
      margin: 0 auto;
    }

    .spec-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem;
    }

    @media (min-width: 768px) {
      .spec-grid { grid-template-columns: repeat(3, 1fr); }
    }

    @media (min-width: 1024px) {
      .spec-grid { grid-template-columns: repeat(4, 1fr); }
    }

    .spec-item {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding: 2rem;
      background: var(--bg-secondary);
      border-radius: 16px;
      border: 1px solid var(--border);
      transition: border-color 0.25s ease;
    }

    .spec-item:hover { border-color: var(--accent); }

    .spec-icon {
      font-size: 1.75rem;
      color: var(--accent);
    }

    .spec-label {
      font-size: 0.8125rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .spec-value {
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }

    .spec-detail {
      font-size: 0.875rem;
      color: var(--text-secondary);
      line-height: 1.5;
    }

    .display-section {
      padding: 8rem 2rem;
      background: color-mix(in srgb, var(--accent) 3%, var(--bg-primary));
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .display-content {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    @media (min-width: 1024px) {
      .display-content { grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
    }

    .display-stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .display-stat {
      text-align: center;
    }

    .display-stat-value {
      font-size: 3rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .display-stat-label {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-top: 0.5rem;
    }

    .display-desc {
      font-size: 1.125rem;
      color: var(--text-secondary);
      line-height: 1.7;
      margin-top: 2rem;
    }

    .display-visual {
      position: relative;
    }

    .display-screen {
      aspect-ratio: 16/10;
      border-radius: 24px;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .color-gradient {
      width: 100%;
      height: 100%;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--accent) 0%, color-mix(in srgb, var(--accent) 50%, var(--bg-primary)) 100%);
      opacity: 0.6;
    }

    .performance-section {
      padding: 8rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .perf-cpu {
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 3rem;
      background: var(--bg-secondary);
      border-radius: 24px;
      border: 1px solid var(--border);
      margin-bottom: 3rem;
    }

    .perf-cpu-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: color-mix(in srgb, var(--accent) 20%, transparent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.5rem;
      color: var(--accent);
      flex-shrink: 0;
    }

    .perf-cpu-info {
      flex: 1;
    }

    .perf-cpu-name {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .perf-cpu-detail {
      font-size: 0.9375rem;
      color: var(--text-secondary);
    }

    .perf-ram-row {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .perf-ram-tag {
      padding: 0.5rem 1rem;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 500;
    }

    .perf-ram-tag.active {
      background: color-mix(in srgb, var(--accent) 15%, transparent);
      border-color: var(--accent);
      color: var(--accent);
    }

    .camera-section {
      padding: 8rem 2rem;
      background: var(--bg-secondary);
    }

    .camera-content {
      max-width: 1200px;
      margin: 0 auto;
    }

    .camera-grid {
      display: flex;
      justify-content: center;
      gap: 3rem;
      margin-top: 4rem;
    }

    .camera-lens {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #333 0%, #111 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    }

    .camera-lens-inner {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #666 0%, #222 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .camera-lens-glass {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.3) 0%, transparent 50%, rgba(0,0,0,0.5) 100%);
    }

    .camera-spec {
      text-align: center;
      margin-top: 1rem;
    }

    .camera-spec-value {
      font-size: 1.25rem;
      font-weight: 700;
    }

    .camera-spec-label {
      font-size: 0.8125rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    .audio-section {
      padding: 8rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .audio-wave {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      height: 100px;
      margin: 3rem 0;
    }

    .audio-bar {
      width: 6px;
      background: var(--accent);
      border-radius: 3px;
      height: 20px;
    }

    .security-section {
      padding: 8rem 2rem;
      background: color-mix(in srgb, var(--accent) 5%, var(--bg-primary));
      border-top: 1px solid var(--border);
    }

    .security-content {
      max-width: 1000px;
      margin: 0 auto;
    }

    .security-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-top: 4rem;
    }

    .security-item {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      padding: 1.5rem 2rem;
      background: var(--bg-secondary);
      border-radius: 12px;
      border: 1px solid var(--border);
    }

    .security-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: color-mix(in srgb, var(--accent) 15%, transparent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
      color: var(--accent);
      flex-shrink: 0;
    }

    .security-info {
      flex: 1;
    }

    .security-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
    }

    .security-desc {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .battery-section {
      padding: 8rem 2rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .battery-ring {
      position: relative;
      width: 200px;
      height: 200px;
      margin: 0 auto 3rem;
    }

    .battery-ring-bg {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: 8px solid var(--border);
    }

    .battery-ring-fill {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: 8px solid transparent;
      border-top-color: var(--accent);
      border-right-color: var(--accent);
      transform: rotate(45deg);
    }

    .battery-info {
      text-align: center;
    }

    .battery-value {
      font-size: 3.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .battery-label {
      font-size: 1rem;
      color: var(--text-secondary);
      margin-top: 0.5rem;
    }

    .battery-charging {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-top: 2rem;
    }

    .battery-charge-item {
      text-align: center;
    }

    .battery-charge-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent);
    }

    .battery-charge-label {
      font-size: 0.8125rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    .cta-section {
      padding: 10rem 2rem;
      text-align: center;
      border-top: 1px solid var(--border);
    }

    .cta-content {
      max-width: 600px;
      margin: 0 auto;
    }

    .cta-title {
      font-size: 2.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }

    .cta-desc {
      font-size: 1.125rem;
      color: var(--text-secondary);
      margin-bottom: 3rem;
    }

    .cta-btns {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    @media (max-width: 768px) {
      .hero-title { font-size: 2.5rem; }
      .hero-subtitle { font-size: 1.25rem; }
      .spec-grid { grid-template-columns: 1fr; }
      .camera-grid { flex-direction: column; align-items: center; }
      .display-stat-value { font-size: 2rem; }
      .battery-value { font-size: 2.5rem; }
    }
  </style>

  <!-- Hero Section -->
  <section class="hero-section" id="hero">
    <div class="hero-glow"></div>
    <div class="hero-content">
      <div class="hero-text">
        <span class="hero-eyebrow" data-anime="hero-eyebrow">{product.os}</span>
        <h1 class="hero-title" data-anime="hero-title">
          {product.name}
        </h1>
        <p class="hero-subtitle" data-anime="hero-subtitle">{product.tagline}</p>
        <p class="hero-desc" data-anime="hero-desc">
          搭载 Leaf OS 5 的旗舰级平板电脑，配备 11 英寸 2.5K 120Hz 自适应刷新率屏幕，第3代 Trdom 八核处理器，以及六扬声器超感声学系统。
        </p>
        <div class="hero-ctas" data-anime="hero-ctas">
          <a href="#specs" class="btn btn-primary">查看规格</a>
          <a href="#buy" class="btn btn-outline">了解更多</a>
        </div>
      </div>

      <div class="hero-visual" data-anime="hero-visual">
        <div class="tablet-outline">
          <div class="tablet-screen">
            <div class="tablet-bezel"></div>
            <div class="screen-content">
              <div class="screen-row">
                <div class="screen-icon"><i class="bi bi-window"></i></div>
                <div class="screen-icon"><i class="bi bi-search"></i></div>
                <div class="screen-icon"><i class="bi bi-music"></i></div>
                <div class="screen-icon"><i class="bi bi-camera"></i></div>
              </div>
              <div class="screen-row">
                <div class="screen-icon"><i class="bi bi-settings"></i></div>
                <div class="screen-icon"><i class="bi bi-mail"></i></div>
                <div class="screen-icon"><i class="bi bi-file-text"></i></div>
                <div class="screen-icon"><i class="bi bi-play"></i></div>
              </div>
              <div class="screen-bar">
                <div class="screen-bar-fill" style="width: 60%"></div>
              </div>
            </div>
            <div class="tablet-home-indicator"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Specs Overview -->
  <section class="specs-section" id="specs">
    <div class="section-header" data-anime="specs-header">
      <h2 class="section-title">核心规格</h2>
      <p class="section-desc">Tree Pad 3 配备强大的硬件配置，为你的创意工作提供坚实基础</p>
    </div>

    <div class="spec-grid">
      {specs.map((spec, index) => (
        <div class="spec-item" data-anime={`spec-item-${index}`}>
          <i class={`spec-icon bi ${spec.icon}`}></i>
          <span class="spec-label">{spec.label}</span>
          <span class="spec-value">{spec.value}</span>
          <span class="spec-detail">{spec.detail}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Display Section -->
  <section class="display-section" id="display">
    <div class="display-content">
      <div class="display-info" data-anime="display-info">
        <h2 class="section-title">惊艳视觉</h2>
        <div class="display-stats">
          {displayStats.map((stat, index) => (
            <div class="display-stat" data-anime={`display-stat-${index}`}>
              <div class="display-stat-value">{stat.value}</div>
              <div class="display-stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
        <p class="display-desc">
          HDR10 LED 屏幕支持杜比视界画质标准，带来更丰富的色彩层次和更高的对比度，让每一个画面都栩栩如生。
        </p>
      </div>
      <div class="display-visual" data-anime="display-visual">
        <div class="display-screen">
          <div class="color-gradient"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Performance Section -->
  <section class="performance-section" id="performance">
    <div class="section-header" data-anime="perf-header">
      <h2 class="section-title">强劲性能</h2>
      <p class="section-desc">第3代 Trdom 八核处理器，释放澎湃动力</p>
    </div>

    <div class="perf-cpu" data-anime="perf-cpu">
      <div class="perf-cpu-icon">
        <i class="bi bi-cpu"></i>
      </div>
      <div class="perf-cpu-info">
        <div class="perf-cpu-name">{performance.processor}</div>
        <div class="perf-cpu-detail">CPU 主频 {performance.cpu}，为多任务处理和创意工作提供充足动力</div>
      </div>
    </div>

    <div class="perf-ram" data-anime="perf-ram">
      <h3 class="text-lg font-semibold mb-2">运行内存</h3>
      <div class="perf-ram-row">
        {performance.ram.map((r, i) => (
          <span class={`perf-ram-tag ${i === 2 ? 'active' : ''}`}>{r}</span>
        ))}
      </div>
    </div>

    <div class="perf-rom mt-4" data-anime="perf-rom">
      <h3 class="text-lg font-semibold mb-2">机身存储</h3>
      <div class="perf-ram-row">
        {performance.rom.map((r) => (
          <span class="perf-ram-tag">{r} SSD</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Camera Section -->
  <section class="camera-section" id="camera">
    <div class="camera-content">
      <div class="section-header" data-anime="camera-header">
        <h2 class="section-title">影像系统</h2>
        <p class="section-desc">双摄组合，记录精彩瞬间</p>
      </div>

      <div class="camera-grid">
        <div data-anime="camera-main">
          <div class="camera-lens">
            <div class="camera-lens-inner">
              <div class="camera-lens-glass"></div>
            </div>
          </div>
          <div class="camera-spec">
            <div class="camera-spec-value">{camera.rearMain}</div>
            <div class="camera-spec-label">后置主摄</div>
          </div>
        </div>
        <div data-anime="camera-wide">
          <div class="camera-lens">
            <div class="camera-lens-inner">
              <div class="camera-lens-glass"></div>
            </div>
          </div>
          <div class="camera-spec">
            <div class="camera-spec-value">{camera.rearWide}</div>
            <div class="camera-spec-label">超广角镜头</div>
          </div>
        </div>
        <div data-anime="camera-front">
          <div class="camera-lens">
            <div class="camera-lens-inner">
              <div class="camera-lens-glass"></div>
            </div>
          </div>
          <div class="camera-spec">
            <div class="camera-spec-value">{camera.front}</div>
            <div class="camera-spec-label">前置摄像头</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Audio Section -->
  <section class="audio-section" id="audio">
    <div class="section-header" data-anime="audio-header">
      <h2 class="section-title">沉浸音效</h2>
      <p class="section-desc">六扬声器超感声学模组，带来震撼的空间音频体验</p>
    </div>

    <div class="audio-wave" id="audio-wave">
      {Array.from({ length: 30 }).map((_, i) => (
        <div class="audio-bar" data-anime={`audio-bar-${i}`}></div>
      ))}
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
      <div class="text-center p-4" data-anime="audio-feature-1">
        <i class="text-2xl text-[var(--accent)] mb-2 bi-volume-up"></i>
        <div class="font-semibold">{audio.speakers}</div>
      </div>
      <div class="text-center p-4" data-anime="audio-feature-2">
        <i class="text-2xl text-[var(--accent)] mb-2 bi-headphones"></i>
        <div class="font-semibold">{audio.dolbyAtmos}</div>
      </div>
      <div class="text-center p-4" data-anime="audio-feature-3">
        <i class="text-2xl text-[var(--accent)] mb-2 bi-music"></i>
        <div class="font-semibold">{audio.customSound}</div>
      </div>
      <div class="text-center p-4" data-anime="audio-feature-4">
        <i class="text-2xl text-[var(--accent)] mb-2 bi-mic"></i>
        <div class="font-semibold">{audio.mics}</div>
      </div>
    </div>
  </section>

  <!-- Security Section -->
  <section class="security-section" id="security">
    <div class="security-content">
      <div class="section-header" data-anime="security-header">
        <h2 class="section-title">安全防护</h2>
        <p class="section-desc">全场景安全体系，守护你的数据与隐私</p>
      </div>

      <div class="security-list">
        {securityItems.map((item, index) => (
          <div class="security-item" data-anime={`security-item-${index}`}>
            <div class="security-icon"><i class={`bi ${item.icon}`}></i></div>
            <div class="security-info">
              <div class="security-title">{item.title}</div>
              <div class="security-desc">{item.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Battery Section -->
  <section class="battery-section" id="battery">
    <div class="section-header" data-anime="battery-header">
      <h2 class="section-title">续航与充电</h2>
      <p class="section-desc">大容量电池配合超级快充，让你时刻保持在线</p>
    </div>

    <div class="battery-ring" data-anime="battery-ring">
      <div class="battery-ring-bg"></div>
      <div class="battery-ring-fill"></div>
    </div>

    <div class="battery-info">
      <div class="battery-value">{battery.capacity}</div>
      <div class="battery-label">等效电池容量</div>
    </div>

    <div class="battery-charging">
      <div class="battery-charge-item" data-anime="battery-charge-1">
        <div class="battery-charge-value">{battery.fastCharge}</div>
        <div class="battery-charge-label">Nature APT 超级快充</div>
      </div>
      <div class="battery-charge-item" data-anime="battery-charge-2">
        <div class="battery-charge-value">{battery.pdCharge}</div>
        <div class="battery-charge-label">PD 快充兼容</div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section" id="buy">
    <div class="cta-content">
      <h2 class="cta-title" data-anime="cta-title">开始你的创意之旅</h2>
      <p class="cta-desc" data-anime="cta-desc">
        Tree Pad 3，搭载 Leaf OS 5，为创作而生。
      </p>
      <div class="cta-btns">
        <a href="#" class="btn btn-primary" data-anime="cta-btn-primary">立即购买</a>
        <a href="#specs" class="btn btn-outline" data-anime="cta-btn-outline">查看完整规格</a>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.addEventListener('DOMContentLoaded', () => {
    if (!prefersReducedMotion) {
      gsap.set('.hero-glow', { scale: 0.5, opacity: 0 });

      const heroTl = gsap.timeline({ delay: 0.3 });

    heroTl
      .to('.hero-glow', { 
        scale: 1, 
        opacity: 1, 
        duration: 2, 
        ease: 'power4.out' 
      })
      .from('[data-anime="hero-eyebrow"]', { 
        opacity: 0, 
        y: 30, 
        duration: 0.8, 
        ease: 'power3.out' 
      }, '-=1.5')
      .from('[data-anime="hero-title"]', { 
        opacity: 0, 
        y: 50, 
        duration: 1, 
        ease: 'power4.out',
        stagger: { each: 0.1 }
      }, '-=0.6')
      .from('[data-anime="hero-subtitle"]', { 
        opacity: 0, 
        y: 40, 
        duration: 0.8, 
        ease: 'power3.out' 
      }, '-=0.5')
      .from('[data-anime="hero-desc"]', { 
        opacity: 0, 
        y: 30, 
        duration: 0.8, 
        ease: 'power3.out' 
      }, '-=0.4')
      .from('[data-anime="hero-ctas"]', { 
        opacity: 0, 
        y: 20, 
        duration: 0.6, 
        ease: 'back.out(1.7)' 
      }, '-=0.3')
      .from('[data-anime="hero-visual"]', { 
        opacity: 0, 
        scale: 0.7, 
        rotationY: -15,
        duration: 1.2, 
        ease: 'back.out(1.7)' 
      }, '-=0.8');

    gsap.from('.screen-icon', {
      opacity: 0,
      scale: 0,
      duration: 0.5,
      ease: 'back.out(1.5)',
      stagger: { each: 0.05 },
      delay: 1.5
    });

    gsap.from('.screen-bar-fill', {
      scaleX: 0,
      duration: 1,
      ease: 'power2.out',
      delay: 2
    });

    const createScrollReveal = (trigger: string, selector: string, vars: Record<string, unknown> = {}) => {
      gsap.from(selector, {
        ...{
          opacity: 0,
          y: 60,
          duration: 0.8,
          ease: 'power3.out',
          stagger: { each: 0.1 }
        },
        ...vars,
        scrollTrigger: {
          trigger: trigger,
          start: 'top 85%',
          once: true
        }
      });
    };

    createScrollReveal('#specs', '[data-anime^="spec-item"]', {
      stagger: { each: 0.08, grid: [2, 4] },
      y: 40
    });

    createScrollReveal('#specs', '[data-anime="specs-header"]', {
      stagger: null,
      duration: 0.6
    });

    createScrollReveal('#display', '[data-anime="display-info"]', {
      x: -50,
      stagger: null
    });

    createScrollReveal('#display', '[data-anime^="display-stat"]', {
      scale: 0.8,
      stagger: { each: 0.1 }
    });

    createScrollReveal('#display', '[data-anime="display-visual"]', {
      scale: 0.85,
      rotateY: -10,
      stagger: null,
      duration: 1
    });

    createScrollReveal('#performance', '[data-anime="perf-header"]', {
      stagger: null
    });

    gsap.from('[data-anime="perf-cpu"]', {
      opacity: 0,
      y: 50,
      scale: 0.95,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#performance',
        start: 'top 80%',
        once: true
      }
    });

    createScrollReveal('#performance', '[data-anime="perf-ram"], [data-anime="perf-rom"]', {
      x: 30,
      duration: 0.6
    });

    createScrollReveal('#camera', '[data-anime="camera-header"]', {
      stagger: null
    });

    gsap.from('[data-anime^="camera-"]', {
      opacity: 0,
      scale: 0.5,
      duration: 0.8,
      ease: 'back.out(1.5)',
      stagger: { each: 0.15 },
      scrollTrigger: {
        trigger: '#camera',
        start: 'top 80%',
        once: true
      }
    });

    gsap.from('.camera-lens', {
      rotate: 360,
      duration: 2,
      ease: 'none',
      scrollTrigger: {
        trigger: '#camera',
        start: 'top 70%',
        once: true
      }
    });

    createScrollReveal('#audio', '[data-anime="audio-header"]', {
      stagger: null
    });

    const audioBars = gsap.utils.toArray('[data-anime^="audio-bar"]');
    gsap.from(audioBars, {
      height: 0,
      duration: 0.8,
      ease: 'elastic.out(1, 0.3)',
      stagger: { each: 0.02 },
      scrollTrigger: {
        trigger: '#audio',
        start: 'top 80%',
        once: true
      }
    });

    createScrollReveal('#audio', '[data-anime^="audio-feature"]', {
      scale: 0.8,
      stagger: { each: 0.1 }
    });

    gsap.to(audioBars, {
      height: () => `${20 + Math.random() * 80}px`,
      duration: 0.3,
      ease: 'sine.inOut',
      stagger: { each: 0.03 },
      repeat: -1,
      yoyo: true,
      scrollTrigger: {
        trigger: '#audio',
        start: 'top 60%',
        toggleActions: 'play pause resume reverse'
      }
    });

    createScrollReveal('#security', '[data-anime="security-header"]', {
      stagger: null
    });

    gsap.from('[data-anime^="security-item"]', {
      opacity: 0,
      x: -50,
      duration: 0.7,
      ease: 'power3.out',
      stagger: { each: 0.1 },
      scrollTrigger: {
        trigger: '#security',
        start: 'top 80%',
        once: true
      }
    });

    gsap.from('.security-icon', {
      rotate: -180,
      duration: 0.8,
      ease: 'back.out(1.5)',
      stagger: { each: 0.1 },
      scrollTrigger: {
        trigger: '#security',
        start: 'top 75%',
        once: true
      }
    });

    createScrollReveal('#battery', '[data-anime="battery-header"]', {
      stagger: null
    });

    gsap.from('[data-anime="battery-ring"]', {
      opacity: 0,
      scale: 0.3,
      duration: 1,
      ease: 'back.out(1.7)',
      scrollTrigger: {
        trigger: '#battery',
        start: 'top 75%',
        once: true
      }
    });

    gsap.to('.battery-ring-fill', {
      rotation: 360,
      duration: 8,
      ease: 'none',
      repeat: -1,
      scrollTrigger: {
        trigger: '#battery',
        start: 'top 70%',
        toggleActions: 'play pause resume pause'
      }
    });

    createScrollReveal('#battery', '[data-anime^="battery-charge"]', {
      y: 30,
      stagger: { each: 0.2 }
    });

    createScrollReveal('#buy', '[data-anime="cta-title"]', {
      scale: 0.9,
      stagger: null
    });

    createScrollReveal('#buy', '[data-anime="cta-desc"]', {
      y: 20,
      stagger: null
    });

    gsap.from('[data-anime^="cta-btn"]', {
      opacity: 0,
      y: 20,
      scale: 0.9,
      duration: 0.5,
      ease: 'back.out(1.5)',
      stagger: { each: 0.1 },
      scrollTrigger: {
        trigger: '#buy',
        start: 'top 85%',
        once: true
      }
    });

    document.querySelectorAll('.btn').forEach(btn => {
      btn.addEventListener('mouseenter', () => {
        gsap.to(btn, {
          scale: 1.05,
          duration: 0.25,
          ease: 'power2.out'
        });
      });

      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, {
          scale: 1,
          duration: 0.25,
          ease: 'power2.out'
        });
      });

      btn.addEventListener('click', () => {
        gsap.to(btn, {
          scale: 0.95,
          duration: 0.1,
          yoyo: true,
          repeat: 1
        });
      });
    });

    document.querySelectorAll('.spec-item').forEach(item => {
      item.addEventListener('mouseenter', () => {
        gsap.to(item, {
          y: -8,
          duration: 0.3,
          ease: 'power2.out'
        });
      });

      item.addEventListener('mouseleave', () => {
        gsap.to(item, {
          y: 0,
          duration: 0.3,
          ease: 'power2.out'
        });
      });
    });

    gsap.to('.hero-glow', {
      scale: 1.2,
      duration: 4,
      ease: 'sine.inOut',
      yoyo: true,
      repeat: -1
    });

    gsap.fromTo('.tablet-outline', {
      rotationY: -5,
    }, {
      rotationY: 5,
      duration: 6,
      ease: 'sine.inOut',
      yoyo: true,
      repeat: -1
    });
    }
  });
</script>