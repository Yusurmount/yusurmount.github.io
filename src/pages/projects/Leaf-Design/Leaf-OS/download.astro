---
import PageLayout from '@/layouts/PageLayout.astro'

const title = '下载中心'
const description = '选择适合您的下载方式，获取最新版本的 Leaf-OS 系统。'
const downloads = [
  {
    icon: 'bi-cloud-arrow-down',
    title: 'WOOZOOO 下载',
    description: '通过蓝奏云下载 Leaf-OS 系统镜像，适合国内用户。',
    link: 'https://wwcy.lanzouq.com/b0ulgk72h',
    linkText: '下载',
    hasPassword: true,
    password: '0000',
  },
  {
    icon: 'bi-github',
    title: 'GitHub 下载',
    description: '访问 GitHub 仓库获取最新版本的 Leaf-OS 系统镜像和源代码。',
    link: 'https://github.com/yusurmount/Leaf-OS/releases',
    linkText: '下载 Release',
    hasPassword: false,
  },
]
---

<PageLayout title={title} description={description}>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    :root {
      --accent: rgb(var(--color-accent));
      --bg-primary: rgb(var(--color-bg-root));
      --bg-secondary: rgb(var(--color-bg-secondary));
      --bg-card: rgb(var(--color-bg-secondary));
      --text-primary: rgb(var(--color-text-primary));
      --text-secondary: rgb(var(--color-text-secondary));
      --border: rgb(var(--color-border-primary));
      --btn-primary-text: white;
    }
    [data-theme='dark'] {
      --btn-primary-text: rgb(255, 255, 255);
    }
    .download-container {
      min-height: calc(100vh - 64px);
    }
    .download-header {
      text-align: center;
      padding: 4rem 0 2rem;
    }
    .download-heading {
      font-size: 2.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }
    .download-subheading {
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.6;
    }
    .download-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      padding: 2rem 0;
    }
    .download-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      transition: border-color 0.2s ease, transform 0.2s ease;
    }
    .download-card:hover {
      border-color: var(--accent);
      transform: translateY(-4px);
    }
    .download-card-icon {
      font-size: 2.5rem;
      color: var(--accent);
      margin-bottom: 1.5rem;
    }
    .download-card-title {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .download-card-desc {
      color: var(--text-secondary);
      line-height: 1.6;
      margin-bottom: 1.5rem;
      flex-grow: 1;
    }
    .download-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.875rem 1.5rem;
      background: var(--accent);
      color: var(--btn-primary-text);
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      transition: filter 0.2s ease, transform 0.2s ease;
      width: 100%;
    }
    .download-btn:hover {
      filter: brightness(0.9);
      transform: translateY(-2px);
    }
    .password-note {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1rem;
      padding: 0.75rem 1rem;
      background: color-mix(in srgb, var(--accent) 10%, transparent);
      border-radius: 8px;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }
    .password-note i {
      color: var(--accent);
    }
    .release-notes {
      margin-top: 4rem;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
    }
    .release-notes-title {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .release-notes-title i {
      color: var(--accent);
    }
    .release-notes-desc {
      color: var(--text-secondary);
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }
    .release-notes-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.875rem 1.5rem;
      background: var(--accent);
      color: var(--btn-primary-text);
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      transition: filter 0.2s ease;
    }
    .release-notes-btn:hover {
      filter: brightness(0.9);
    }
    @media (max-width: 768px) {
      .download-header {
        padding: 2rem 0 1rem;
      }
      .download-heading {
        font-size: 2rem;
      }
      .download-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="download-container">
    <div class="max-w-[1100px] px-4 md:px-8 mx-auto">
      <!-- Header -->
      <header class="download-header">
        <h1 class="download-heading">Leaf-OS 下载中心</h1>
        <p class="download-subheading">
          选择适合您的下载方式，获取最新版本的 Leaf-OS 系统。
        </p>
      </header>

      <!-- Download Cards -->
      <div class="download-grid">
        {downloads.map((item) => (
          <div class="download-card">
            <i class={`bi ${item.icon} download-card-icon`}></i>
            <h2 class="download-card-title">{item.title}</h2>
            <p class="download-card-desc">{item.description}</p>
            <a href={item.link} target="_blank" rel="noopener" class="download-btn">
              <i class="bi bi-download"></i>
              {item.linkText}
            </a>
            {item.hasPassword && (
              <div class="password-note">
                <i class="bi bi-lock"></i>
                <span>提取码：{item.password}</span>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Release Notes -->
      <div class="release-notes">
        <h2 class="release-notes-title">
          <i class="bi bi-file-text"></i>
          更新日志
        </h2>
        <p class="release-notes-desc">
          查看 Leaf-OS 的最新更新内容和版本历史记录。
        </p>
        <a href="http://intereco.org.cn/u/56" target="_blank" rel="noopener" class="release-notes-btn">
          <i class="bi bi-arrow-right"></i>
          查看更新日志
        </a>
      </div>
    </div>
  </div>
</PageLayout>