---
import PageLayout from '@/layouts/PageLayout.astro'
import { getOldestDocs } from '@/utils/content'
import DocTimeline from '@/components/DocTimeline.astro'
import Highlight from '@/components/Highlight.astro'

const oldestDocs = await getOldestDocs()
---

<PageLayout title="文档">
  <div class="max-w-[800px] mx-auto px-4 py-16">
    <header class="space-y-4 mb-8">
      <h1 class="text-4xl font-bold">
        <Highlight>文档</Highlight>
      </h1>
      <p>共有 {oldestDocs.length} 篇文档。</p>
    </header>
    <DocTimeline posts={oldestDocs} />
  </div>
</PageLayout>