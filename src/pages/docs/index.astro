---
import PageLayout from '@/layouts/PageLayout.astro'
import { getAllDocCategories } from '@/utils/content'
import DocCategoryList from '@/components/DocCategoryList.astro'
import Highlight from '@/components/Highlight.astro'

const categories = await getAllDocCategories()
---

<PageLayout title="文档">
  <div class="max-w-[800px] mx-auto px-4 py-16">
    <header class="space-y-4 mb-8">
      <h1 class="text-4xl font-bold">
        <Highlight>文档</Highlight>
      </h1>
      <p>共有 {categories.length} 个分类。</p>
    </header>
    <DocCategoryList categories={categories} />
  </div>
</PageLayout>